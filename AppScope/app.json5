{
  "app": {
    "bundleName": "com.zhuzx.webdavhelper",
    "icon": "$media:layered_image",
    "label": "$string:app_name",
    "versionCode": 2,
    "versionName": "1.0.0.1",
    "multiAppMode": {
      "multiAppModeType": "appClone",
      "maxCount": 5
    },
    "configuration": "$profile:configuration",
    "appPreloadPhase": "abilityStageCreated"
  }
}